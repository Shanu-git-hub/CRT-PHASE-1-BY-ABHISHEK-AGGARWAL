//If statement 
#include <iostream>
using namespace std;

int main() {
    int age;
    cin >> age;

    if (age >= 18) {
        cout << "Eligible";
    }

    return 0;
}

//if else statement
#include <iostream>
using namespace std;

int main() {
    int age;

    cin >> age;   // take input

    if (age >= 18) {
        cout << "Eligible for vote";
    } else {
        cout << "Not eligible";
    }

    return 0;
}
